<?xml version="1.0"?>
<sdf version="1.7">

    <!--include defination-->
    <xmacro_include uri="model://mid360/model.sdf.xmacro" />
    <xmacro_include uri="model://industrial_camera/model.sdf.xmacro" />

    <!--property defination（2026 赛季实车参数：25kg，轮距 0.50m，底盘长 0.35m）

         为什么 4 轮 skid-steer 而非 2 轮+caster:
         - 实车是轮足双轮 + 主动平衡控制器, 2 接触点
         - 仿真里没有平衡控制器, 2 轮 + 2 caster 的 3 接触点在 DART 引擎下
           数值不稳定（rosbag 显示 IMU az std=12 物理发散）
         - 工业仿真惯例用 4 轮 skid-steer: 4 接触点稳定, 左右同侧同速驱动
           形成差速转向, Nav2 视角 (vx, wz) 与轮足完全等价
         - 实车部署时只需驱动 2 个电机, 前后轮视为同轴（或直接删掉前轮）
    -->
    <xmacro_define_value name="chassis_height" value="0.15" />
    <xmacro_define_value name="chassis_length" value="0.35" />
    <xmacro_define_value name="chassis_width" value="0.40" />
    <xmacro_define_value name="chassis_z" value="0.12" />

    <xmacro_define_value name="wheel_radius" value="0.076" />
    <xmacro_define_value name="wheel_width" value="0.04" />

    <!-- 4 轮 skid-steer:
         横向 wheel_separation = 0.50m (左右轮中心距)
         纵向 wheel_base = 0.22m (前后轮中心距, 底盘长 0.35m 内留 6.5cm 边距) -->
    <xmacro_define_value name="wheel_separation" value="0.50" />
    <xmacro_define_value name="half_wheel_sep" value="0.25" />
    <xmacro_define_value name="neg_half_wheel_sep" value="-0.25" />
    <xmacro_define_value name="half_wheel_base" value="0.11" />
    <xmacro_define_value name="neg_half_wheel_base" value="-0.11" />

    <xmacro_define_value name="gimbal_yaw_height" value="0.18" />
    <xmacro_define_value name="gimbal_pitch_height" value="0.08" />

    <!--wheeled robot model-->
    <model name="wheeled_biped">

        <pose>0 0 ${chassis_height} 0 0 0</pose>

        <!--base footprint (ground projection)-->
        <link name="base_footprint"/>

        <joint name="base_to_chassis" type="fixed">
            <pose relative_to="base_footprint">0 0 ${chassis_height} 0 0 0</pose>
            <parent>base_footprint</parent>
            <child>chassis</child>
        </joint>

        <!--chassis body (25kg, 0.35x0.40x0.12)-->
        <link name="chassis">
            <inertial>
                <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                <mass>25.0</mass>
                <!-- 25kg 箱体理论惯量（m/12*(a²+b²)）:
                     ixx (roll)  = 0.363
                     iyy (pitch) = 0.285
                     izz (yaw)   = 0.589
                     4 轮 skid-steer 物理稳定不需要靠惯量压振, 用接近理论值即可。
                     三角不等式验证: 0.40+0.60=1.0>0.40 ✓, 0.40+0.40=0.80>0.60 ✓ -->
                <inertia>
                    <ixx>0.40</ixx>
                    <iyy>0.40</iyy>
                    <izz>0.60</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="chassis_visual">
                <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                <geometry>
                    <box>
                        <size>${chassis_length} ${chassis_width} ${chassis_z}</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.2 0.2 0.25 1</ambient>
                    <diffuse>0.3 0.3 0.35 1</diffuse>
                </material>
            </visual>
            <collision name="chassis_collision">
                <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                <geometry>
                    <box>
                        <size>${chassis_length} ${chassis_width} ${chassis_z}</size>
                    </box>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.3</mu>
                            <mu2>0.3</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <sensor name="chassis_imu" type="imu">
                <always_on>1</always_on>
                <update_rate>200</update_rate>
            </sensor>
        </link>

        <!--
            4 轮布局（俯视）:
                  [front_left]       [front_right]
                        |  chassis  |
                  [rear_left]        [rear_right]
            左侧两轮 (front_left + rear_left) 由 DiffDrive 同速驱动
            右侧两轮 (front_right + rear_right) 由 DiffDrive 同速驱动
            左右不同速 → skid-steer 差速转向
        -->

        <!--front_left wheel-->
        <joint name="front_left_wheel_joint" type="revolute">
            <pose relative_to="chassis">${half_wheel_base} ${half_wheel_sep} 0 -1.5708 0 0</pose>
            <parent>chassis</parent>
            <child>front_left_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
                <limit>
                    <effort>200</effort>
                    <velocity>80</velocity>
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
                <dynamics>
                    <damping>0.05</damping>
                </dynamics>
            </axis>
        </joint>
        <link name="front_left_wheel">
            <pose relative_to="front_left_wheel_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>1.0</mass>
                <inertia>
                    <ixx>0.003</ixx>
                    <iyy>0.003</iyy>
                    <izz>0.0029</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.15 0.15 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.5</mu2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1e7</kp>
                            <kd>500</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <!--front_right wheel-->
        <joint name="front_right_wheel_joint" type="revolute">
            <pose relative_to="chassis">${half_wheel_base} ${neg_half_wheel_sep} 0 -1.5708 0 0</pose>
            <parent>chassis</parent>
            <child>front_right_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
                <limit>
                    <effort>200</effort>
                    <velocity>80</velocity>
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
                <dynamics>
                    <damping>0.05</damping>
                </dynamics>
            </axis>
        </joint>
        <link name="front_right_wheel">
            <pose relative_to="front_right_wheel_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>1.0</mass>
                <inertia>
                    <ixx>0.003</ixx>
                    <iyy>0.003</iyy>
                    <izz>0.0029</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.15 0.15 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.5</mu2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1e7</kp>
                            <kd>500</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <!--rear_left wheel-->
        <joint name="rear_left_wheel_joint" type="revolute">
            <pose relative_to="chassis">${neg_half_wheel_base} ${half_wheel_sep} 0 -1.5708 0 0</pose>
            <parent>chassis</parent>
            <child>rear_left_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
                <limit>
                    <effort>200</effort>
                    <velocity>80</velocity>
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
                <dynamics>
                    <damping>0.05</damping>
                </dynamics>
            </axis>
        </joint>
        <link name="rear_left_wheel">
            <pose relative_to="rear_left_wheel_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>1.0</mass>
                <inertia>
                    <ixx>0.003</ixx>
                    <iyy>0.003</iyy>
                    <izz>0.0029</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.15 0.15 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.5</mu2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1e7</kp>
                            <kd>500</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <!--rear_right wheel-->
        <joint name="rear_right_wheel_joint" type="revolute">
            <pose relative_to="chassis">${neg_half_wheel_base} ${neg_half_wheel_sep} 0 -1.5708 0 0</pose>
            <parent>chassis</parent>
            <child>rear_right_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
                <limit>
                    <effort>200</effort>
                    <velocity>80</velocity>
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
                <dynamics>
                    <damping>0.05</damping>
                </dynamics>
            </axis>
        </joint>
        <link name="rear_right_wheel">
            <pose relative_to="rear_right_wheel_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>1.0</mass>
                <inertia>
                    <ixx>0.003</ixx>
                    <iyy>0.003</iyy>
                    <izz>0.0029</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.15 0.15 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.5</mu2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1e7</kp>
                            <kd>500</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <!--gimbal yaw joint (independent from chassis orientation)-->
        <joint name="gimbal_yaw_joint" type="revolute">
            <pose relative_to="chassis">0 0 ${gimbal_yaw_height} 0 0 0</pose>
            <parent>chassis</parent>
            <child>gimbal_yaw</child>
            <axis>
                <xyz>0 0 1</xyz>
                <limit>
                    <effort>20</effort>
                    <velocity>50</velocity>
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
            </axis>
        </joint>
        <link name="gimbal_yaw">
            <pose relative_to="gimbal_yaw_joint">0 0 0 0 0 0</pose>
            <inertial>
                <pose>0 0 0.04 0 0 0</pose>
                <mass>0.5</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.0015</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0.04 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.08 0.08 0.08</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.4 0.4 0.45 1</ambient>
                    <diffuse>0.5 0.5 0.55 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0 0 0.04 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.08 0.08 0.08</size>
                    </box>
                </geometry>
            </collision>
        </link>

        <!--gimbal pitch joint-->
        <joint name="gimbal_pitch_joint" type="revolute">
            <pose relative_to="gimbal_yaw">0 0 ${gimbal_pitch_height} 0 0 0</pose>
            <parent>gimbal_yaw</parent>
            <child>gimbal_pitch</child>
            <axis>
                <xyz>0 1 0</xyz>
                <limit>
                    <effort>20</effort>
                    <velocity>50</velocity>
                    <lower>${-3.14*0.25}</lower>
                    <upper>${3.14*0.18}</upper>
                </limit>
            </axis>
        </joint>
        <link name="gimbal_pitch">
            <pose relative_to="gimbal_pitch_joint">0 0 0 0 0 0</pose>
            <inertial>
                <pose>0.03 0 0 0 0 0</pose>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.0005</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.001</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0.03 0 0 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.12 0.06 0.06</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.5 0.2 0.2 1</ambient>
                    <diffuse>0.6 0.25 0.25 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0.03 0 0 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.12 0.06 0.06</size>
                    </box>
                </geometry>
            </collision>
        </link>

        <!--LiDAR (Livox Mid360) mounted on gimbal_pitch, rotates with gimbal-->
        <xmacro_block name="livox" prefix="front_" parent="gimbal_pitch" pose="-0.05 0 0.05 0 0 ${pi}" update_rate="50" samples="1875"/>

        <!--industrial camera mounted on gimbal_pitch-->
        <xmacro_block name="industrial_camera" prefix="front_" parent="gimbal_pitch" pose="0.08 0 0.02 0 0 0" update_rate="30" horizontal_fov="1" width="1920" height="1080"/>

        <!--joint state publisher-->
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
        </plugin>

        <!--differential drive (skid-steer: 左/右各指定 2 个 joint)
             不显式指定 topic, gz-sim 默认用 /model/<model_name>/cmd_vel -->
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>front_left_wheel_joint</left_joint>
            <left_joint>rear_left_wheel_joint</left_joint>
            <right_joint>front_right_wheel_joint</right_joint>
            <right_joint>rear_right_wheel_joint</right_joint>
            <wheel_separation>${wheel_separation}</wheel_separation>
            <wheel_radius>${wheel_radius}</wheel_radius>
            <odom_publish_frequency>0</odom_publish_frequency>
            <frame_id>odom</frame_id>
            <child_frame_id>chassis</child_frame_id>
            <tf_topic>/tf_diff_drive_unused</tf_topic>
        </plugin>

        <!--gimbal yaw joint controller-->
        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>gimbal_yaw_joint</joint_name>
            <use_force_commands>false</use_force_commands>
            <p_gain>0.2</p_gain>
            <i_gain>0.01</i_gain>
        </plugin>

        <!--gimbal pitch joint controller-->
        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>gimbal_pitch_joint</joint_name>
            <use_force_commands>false</use_force_commands>
            <p_gain>1</p_gain>
            <i_gain>0.01</i_gain>
        </plugin>
    </model>
</sdf>
