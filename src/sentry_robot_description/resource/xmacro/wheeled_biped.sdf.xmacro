<?xml version="1.0"?>
<sdf version="1.7">

    <!--include defination-->
    <xmacro_include uri="model://mid360/model.sdf.xmacro" />
    <xmacro_include uri="model://industrial_camera/model.sdf.xmacro" />

    <!--property defination（2026 赛季实车参数：25kg，轮距 0.50m，底盘长 0.35m）-->
    <xmacro_define_value name="chassis_height" value="0.15" />
    <xmacro_define_value name="chassis_length" value="0.35" />
    <xmacro_define_value name="chassis_width" value="0.40" />
    <xmacro_define_value name="chassis_z" value="0.12" />

    <xmacro_define_value name="wheel_radius" value="0.076" />
    <xmacro_define_value name="wheel_width" value="0.04" />
    <xmacro_define_value name="wheel_separation" value="0.50" />
    <xmacro_define_value name="half_wheel_sep" value="0.25" />
    <xmacro_define_value name="neg_half_wheel_sep" value="-0.25" />

    <xmacro_define_value name="gimbal_yaw_height" value="0.18" />
    <xmacro_define_value name="gimbal_pitch_height" value="0.08" />

    <!-- caster 球形支撑轮：仅用于仿真中让底盘稳定站立，避免两轮倒立摆
         实车是轮足双轮，平衡由关节控制器维持；仿真里没有轮足控制器，
         用无摩擦 caster 作为被动支撑点，和真实轮足表现等价（都是
         vx/wz 差速） -->
    <xmacro_define_value name="caster_radius" value="0.025" />
    <!-- caster 位置硬编码：
         caster_offset_x_front = 0.14（底盘中心到前 caster 的 x 距离，
                                     略小于 chassis_length/2 = 0.175 确保在底盘内）
         caster_offset_x_rear  = -0.14
         caster_z = -(wheel_radius - caster_radius) = -(0.076 - 0.025) = -0.051
                    使 caster 触地点与两驱动轮触地点齐平 -->
    <xmacro_define_value name="caster_offset_x_front" value="0.14" />
    <xmacro_define_value name="caster_offset_x_rear" value="-0.14" />
    <xmacro_define_value name="caster_z" value="-0.051" />

    <!--wheeled biped robot model-->
    <model name="wheeled_biped">

        <pose>0 0 ${chassis_height} 0 0 0</pose>

        <!--base footprint (ground projection)-->
        <link name="base_footprint"/>

        <joint name="base_to_chassis" type="fixed">
            <pose relative_to="base_footprint">0 0 ${chassis_height} 0 0 0</pose>
            <parent>base_footprint</parent>
            <child>chassis</child>
        </joint>

        <!--chassis body (25kg，0.35×0.40×0.12 箱体)-->
        <link name="chassis">
            <inertial>
                <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                <mass>25.0</mass>
                <!-- 25kg 箱体理论惯量（m/12*(a²+b²)）：
                     ixx (roll, y²+z²=0.174)  = 0.363
                     iyy (pitch, x²+z²=0.137) = 0.285
                     izz (yaw, x²+y²=0.283)   = 0.589
                     用接近理论值避免物理发散：高 iyy 会让 ODE 约束求解
                     数值爆掉（rosbag 里 wz 跑到 100 rad/s 印证）。
                     抑制俯仰靠 caster 间距 + 接触 kp/kd，不靠惯量压。
                     验证三角不等式：
                     0.40+0.60=1.0>0.40 ✓, 0.40+0.40=0.80>0.60 ✓, 0.60+0.40=1.00>0.40 ✓ -->
                <inertia>
                    <ixx>0.40</ixx>
                    <iyy>0.40</iyy>
                    <izz>0.60</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="chassis_visual">
                <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                <geometry>
                    <box>
                        <size>${chassis_length} ${chassis_width} ${chassis_z}</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.2 0.2 0.25 1</ambient>
                    <diffuse>0.3 0.3 0.35 1</diffuse>
                </material>
            </visual>
            <collision name="chassis_collision">
                <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                <geometry>
                    <box>
                        <size>${chassis_length} ${chassis_width} ${chassis_z}</size>
                    </box>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.3</mu>
                            <mu2>0.3</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <sensor name="chassis_imu" type="imu">
                <always_on>1</always_on>
                <update_rate>200</update_rate>
            </sensor>
        </link>

        <!--left drive wheel-->
        <joint name="left_wheel_joint" type="revolute">
            <pose relative_to="chassis">0 ${half_wheel_sep} 0 -1.5708 0 0</pose>
            <parent>chassis</parent>
            <child>left_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
                <limit>
                    <effort>200</effort>                <!-- 100→200 N·m，25kg 底盘需要更大扭矩 -->
                    <velocity>80</velocity>             <!-- 50→80 rad/s，支持更高速 -->
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
                <dynamics>
                    <damping>0.05</damping>
                </dynamics>
            </axis>
        </joint>
        <link name="left_wheel">
            <pose relative_to="left_wheel_joint">0 0 0 0 0 0</pose>
            <inertial>
                <!-- 1.0kg 轮子（实车橡胶轮+电机+减速组件整体），
                     惯量按圆柱 m*r²/2 (izz=转轴) 估算 -->
                <mass>1.0</mass>
                <inertia>
                    <ixx>0.003</ixx>
                    <iyy>0.003</iyy>
                    <izz>0.0029</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.15 0.15 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <!-- mu=纵向（驱动方向）摩擦，mu2=侧向摩擦
                                 差速车希望侧向高摩擦防打滑，实车轮足
                                 有类似行为 -->
                            <mu>1.0</mu>
                            <mu2>2.0</mu2>
                        </ode>
                    </friction>
                    <!-- 接触刚度需偏高 (1e7) 避免轮子压陷底盘导致高频抖动，
                         阻尼 kd=500 吸收冲击；rosbag 显示 kp=1e6 时 IMU az
                         标准差飙到 10+ 是物理发散 -->
                    <contact>
                        <ode>
                            <kp>1e7</kp>
                            <kd>500</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <!--right drive wheel-->
        <joint name="right_wheel_joint" type="revolute">
            <pose relative_to="chassis">0 ${neg_half_wheel_sep} 0 -1.5708 0 0</pose>
            <parent>chassis</parent>
            <child>right_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
                <limit>
                    <effort>200</effort>                <!-- 100→200 N·m，25kg 底盘需要更大扭矩 -->
                    <velocity>80</velocity>             <!-- 50→80 rad/s，支持更高速 -->
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
                <dynamics>
                    <damping>0.05</damping>
                </dynamics>
            </axis>
        </joint>
        <link name="right_wheel">
            <pose relative_to="right_wheel_joint">0 0 0 0 0 0</pose>
            <inertial>
                <!-- 1.0kg 轮子（实车橡胶轮+电机+减速组件整体），
                     惯量按圆柱 m*r²/2 (izz=转轴) 估算 -->
                <mass>1.0</mass>
                <inertia>
                    <ixx>0.003</ixx>
                    <iyy>0.003</iyy>
                    <izz>0.0029</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.15 0.15 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <!-- mu=纵向（驱动方向）摩擦，mu2=侧向摩擦
                                 差速车希望侧向高摩擦防打滑，实车轮足
                                 有类似行为 -->
                            <mu>1.0</mu>
                            <mu2>2.0</mu2>
                        </ode>
                    </friction>
                    <!-- 接触刚度需偏高 (1e7) 避免轮子压陷底盘导致高频抖动，
                         阻尼 kd=500 吸收冲击；rosbag 显示 kp=1e6 时 IMU az
                         标准差飙到 10+ 是物理发散 -->
                    <contact>
                        <ode>
                            <kp>1e7</kp>
                            <kd>500</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <!--front caster（被动球形支撑轮，低摩擦，防止底盘倒立摆翻倒）-->
        <joint name="front_caster_joint" type="fixed">
            <pose relative_to="chassis">${caster_offset_x_front} 0 ${caster_z} 0 0 0</pose>
            <parent>chassis</parent>
            <child>front_caster</child>
        </joint>
        <link name="front_caster">
            <pose relative_to="front_caster_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>0.05</mass>
                <inertia>
                    <ixx>1.25e-5</ixx>
                    <iyy>1.25e-5</iyy>
                    <izz>1.25e-5</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <sphere><radius>${caster_radius}</radius></sphere>
                </geometry>
                <material>
                    <ambient>0.3 0.3 0.3 1</ambient>
                    <diffuse>0.4 0.4 0.4 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <sphere><radius>${caster_radius}</radius></sphere>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.01</mu>
                            <mu2>0.01</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
        </link>

        <!--rear caster-->
        <joint name="rear_caster_joint" type="fixed">
            <pose relative_to="chassis">${caster_offset_x_rear} 0 ${caster_z} 0 0 0</pose>
            <parent>chassis</parent>
            <child>rear_caster</child>
        </joint>
        <link name="rear_caster">
            <pose relative_to="rear_caster_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>0.05</mass>
                <inertia>
                    <ixx>1.25e-5</ixx>
                    <iyy>1.25e-5</iyy>
                    <izz>1.25e-5</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <sphere><radius>${caster_radius}</radius></sphere>
                </geometry>
                <material>
                    <ambient>0.3 0.3 0.3 1</ambient>
                    <diffuse>0.4 0.4 0.4 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <sphere><radius>${caster_radius}</radius></sphere>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.01</mu>
                            <mu2>0.01</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
        </link>

        <!--gimbal yaw joint (independent from chassis orientation)-->
        <joint name="gimbal_yaw_joint" type="revolute">
            <pose relative_to="chassis">0 0 ${gimbal_yaw_height} 0 0 0</pose>
            <parent>chassis</parent>
            <child>gimbal_yaw</child>
            <axis>
                <xyz>0 0 1</xyz>
                <limit>
                    <effort>20</effort>
                    <velocity>50</velocity>
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
            </axis>
        </joint>
        <link name="gimbal_yaw">
            <pose relative_to="gimbal_yaw_joint">0 0 0 0 0 0</pose>
            <inertial>
                <pose>0 0 0.04 0 0 0</pose>
                <mass>0.5</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.0015</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0.04 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.08 0.08 0.08</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.4 0.4 0.45 1</ambient>
                    <diffuse>0.5 0.5 0.55 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0 0 0.04 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.08 0.08 0.08</size>
                    </box>
                </geometry>
            </collision>
        </link>

        <!--gimbal pitch joint-->
        <joint name="gimbal_pitch_joint" type="revolute">
            <pose relative_to="gimbal_yaw">0 0 ${gimbal_pitch_height} 0 0 0</pose>
            <parent>gimbal_yaw</parent>
            <child>gimbal_pitch</child>
            <axis>
                <xyz>0 1 0</xyz>
                <limit>
                    <effort>20</effort>
                    <velocity>50</velocity>
                    <lower>${-3.14*0.25}</lower>
                    <upper>${3.14*0.18}</upper>
                </limit>
            </axis>
        </joint>
        <link name="gimbal_pitch">
            <pose relative_to="gimbal_pitch_joint">0 0 0 0 0 0</pose>
            <inertial>
                <pose>0.03 0 0 0 0 0</pose>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.0005</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.001</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0.03 0 0 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.12 0.06 0.06</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.5 0.2 0.2 1</ambient>
                    <diffuse>0.6 0.25 0.25 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0.03 0 0 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.12 0.06 0.06</size>
                    </box>
                </geometry>
            </collision>
        </link>

        <!--LiDAR (Livox Mid360) mounted on gimbal_pitch, rotates with gimbal-->
        <xmacro_block name="livox" prefix="front_" parent="gimbal_pitch" pose="-0.05 0 0.05 0 0 ${pi}" update_rate="50" samples="1875"/>

        <!--industrial camera mounted on gimbal_pitch-->
        <xmacro_block name="industrial_camera" prefix="front_" parent="gimbal_pitch" pose="0.08 0 0.02 0 0 0" update_rate="30" horizontal_fov="1" width="1920" height="1080"/>

        <!--joint state publisher (Gazebo Harmonic: gz-sim-* naming)-->
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
        </plugin>

        <!--differential drive; 不显式指定 topic，让 gz-sim 默认用
             /model/<model_name>/cmd_vel，与 ros_gz_bridge 目标一致-->
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>
            <wheel_separation>${wheel_separation}</wheel_separation>
            <wheel_radius>${wheel_radius}</wheel_radius>
            <odom_publish_frequency>0</odom_publish_frequency>
            <frame_id>odom</frame_id>
            <child_frame_id>chassis</child_frame_id>
            <tf_topic>/tf_diff_drive_unused</tf_topic>
        </plugin>

        <!--gimbal yaw joint controller-->
        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>gimbal_yaw_joint</joint_name>
            <use_force_commands>false</use_force_commands>
            <p_gain>0.2</p_gain>
            <i_gain>0.01</i_gain>
        </plugin>

        <!--gimbal pitch joint controller-->
        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>gimbal_pitch_joint</joint_name>
            <use_force_commands>false</use_force_commands>
            <p_gain>1</p_gain>
            <i_gain>0.01</i_gain>
        </plugin>
    </model>
</sdf>
