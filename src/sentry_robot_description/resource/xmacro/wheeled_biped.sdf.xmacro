<?xml version="1.0"?>
<sdf version="1.8">

    <!--include defination-->
    <xmacro_include uri="model://mid360/model.sdf.xmacro" />
    <xmacro_include uri="model://industrial_camera/model.sdf.xmacro" />

    <!--property defination（2026 赛季实车参数：28kg，底盘 0.648x0.650m，轮径 0.060m，电机扭矩 2.4N·m）

         构型: 2 轮同轴 + 前后 2 caster ball, 模拟轮足平衡控制器
         - 实车是双轮同轴 + 主动平衡控制器, 可原地自旋 (两轮反向同速 → 车身绕几何中心旋转)
         - 仿真无平衡控制器, 裸 2 轮会前后摇摆翻倒
         - caster ball 摩擦 mu=0.01 (极低), 仅提供静态支撑防翻, 不阻碍转向
         - Nav2 视角: 两轮差速 = 原地零回转半径, 与实车轮足一致
         - 实车部署: DiffDrive plugin 对接下位机平衡器, caster 纯仿真 workaround
         - 为减少 LiDAR 自遮挡, 仿真 chassis 盒体仅保留实车尺寸的 65%; 运动学 footprint 不变
    -->
    <!-- chassis 底在 base_footprint 之上的高度 = leg_len + wheel_radius = 0.28m
         几何约束: base_footprint 贴地 (world z=0) → chassis 底 z=chassis_height
                   → wheel_center z=chassis_height-leg_len=0.06 → 轮底 z=0 ✓
         任何偏差都会让 base_footprint 穿地或 wheel 悬空 -->
    <xmacro_define_value name="chassis_height" value="0.28" />
    <xmacro_define_value name="chassis_length" value="0.4212" />
    <xmacro_define_value name="chassis_width" value="0.4225" />
    <xmacro_define_value name="chassis_z" value="0.078" />

    <xmacro_define_value name="wheel_radius" value="0.060" />
    <xmacro_define_value name="wheel_width" value="0.04" />

    <!-- 2 轮同轴 (车身中线, x=0), 轮距 0.65m 贴车身两侧 -->
    <xmacro_define_value name="wheel_separation" value="0.65" />
    <xmacro_define_value name="half_wheel_sep" value="0.325" />
    <xmacro_define_value name="neg_half_wheel_sep" value="-0.325" />

    <!-- caster ball: 前后各一个, x=±0.28.
         为保持 2 轮+2 支撑点的俯仰稳定性, caster offset 不随缩小 chassis 一起改.
         caster_radius=0.030, ball 中心 z=-(leg_len+wheel_radius-caster_radius) 与轮底齐平 -->
    <xmacro_define_value name="caster_offset" value="0.28" />
    <xmacro_define_value name="neg_caster_offset" value="-0.28" />
    <xmacro_define_value name="caster_radius" value="0.030" />
    <xmacro_define_value name="caster_z" value="-0.25" />

    <!-- 虚拟腿长 leg_len: 模拟轮足连杆展开高度, chassis 底离地 = leg_len + wheel_radius
         = 0.22 + 0.06 = 0.28m (实车腿展开典型值 0.25~0.35m).
         wheel joint 在 chassis 坐标系下 z = -leg_len, 相当于 chassis 通过隐式"腿"挂在轮轴上方.
         物理上 chassis->wheel 是 revolute joint, fixed leg 不需要显式 link. -->
    <xmacro_define_value name="leg_len" value="0.22" />
    <xmacro_define_value name="neg_leg_len" value="-0.22" />

    <xmacro_define_value name="gimbal_yaw_height" value="0.18" />
    <xmacro_define_value name="gimbal_pitch_height" value="0.08" />
    <!-- Sensor-only extrinsics: chassis / gimbal stay mechanically upright.
         Any tilted / inverted Mid360 installation must be expressed only here,
         in gimbal_pitch -> front_mid360, never by changing base/gimbal DOF semantics. -->
    <xmacro_define_value name="front_lidar_mount_roll" value="0.0" />
    <xmacro_define_value name="front_lidar_mount_pitch" value="0.523598775598299" />
    <xmacro_define_value name="front_lidar_mount_yaw" value="${pi}" />

    <!--wheeled robot model-->
    <model name="wheeled_biped" canonical_link="chassis" placement_frame="base_footprint">

        <!-- Spawn z controlled by launch -z arg (gz_world.yaml), not here.
             base_footprint is the model origin; launch must spawn it at world z=0
             for wheels to touch ground. -->
        <pose>0 0 0 0 0 0</pose>

        <!--base footprint (ground projection).
             必须带 inertial (哪怕极小): 空 link 在 gz-sim 会被当作 phantom,
             base_to_chassis fixed joint 约束失效 → 整个机器人下坠穿地. -->
        <link name="base_footprint">
            <inertial>
                <mass>0.001</mass>
                <inertia>
                    <ixx>1e-6</ixx>
                    <iyy>1e-6</iyy>
                    <izz>1e-6</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
        </link>

        <joint name="base_to_chassis" type="fixed">
            <pose relative_to="base_footprint">0 0 ${chassis_height} 0 0 0</pose>
            <parent>base_footprint</parent>
            <child>chassis</child>
        </joint>

        <!--chassis body (simulation self-occlusion workaround: 28kg, 0.4212x0.4225x0.078)-->
        <link name="chassis">
            <inertial>
                <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                <mass>28.0</mass>
                <!-- 28kg 箱体理论惯量（车体盒子缩到 65%，仅降低 LiDAR 自遮挡）:
                     ixx (roll)  ~= 28/12*(0.4225²+0.078²) = 0.43
                     iyy (pitch) ~= 28/12*(0.4212²+0.078²) = 0.43
                     izz (yaw)   ~= 28/12*(0.4212²+0.4225²) = 0.83
                     三角不等式验证: 0.44+0.44=0.88>0.84 ✓ -->
                <inertia>
                    <ixx>0.44</ixx>
                    <iyy>0.44</iyy>
                    <izz>0.84</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="chassis_visual">
                <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                <geometry>
                    <box>
                        <size>${chassis_length} ${chassis_width} ${chassis_z}</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.2 0.2 0.25 1</ambient>
                    <diffuse>0.3 0.3 0.35 1</diffuse>
                </material>
            </visual>
            <collision name="chassis_collision">
                <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                <geometry>
                    <box>
                        <size>${chassis_length} ${chassis_width} ${chassis_z}</size>
                    </box>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.3</mu>
                            <mu2>0.3</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
            <sensor name="chassis_imu" type="imu">
                <always_on>1</always_on>
                <update_rate>200</update_rate>
            </sensor>
        </link>

        <!--
            2 轮同轴布局（俯视）:
                     [front_caster]
                  [left_wheel]  |  [right_wheel]
                     [rear_caster]
            左右轮同轴 (x=0) → 两轮反向同速即原地自旋 (与实车轮足平衡一致)
            前后 caster ball 仅防翻, 摩擦极低不干扰转向
        -->

        <!--left wheel (同轴, x=0, z=-leg_len 模拟虚拟腿)-->
        <joint name="left_wheel_joint" type="revolute">
            <pose relative_to="chassis">0 ${half_wheel_sep} ${neg_leg_len} -1.5708 0 0</pose>
            <parent>chassis</parent>
            <child>left_wheel</child>
            <axis>
                <!-- joint pose rpy=-1.5708 0 0 把 joint frame 绕 x 翻 -90°.
                     翻转后: joint_z = model_y (左右方向) = 正确的轮轴.
                     用 expressed_in="__model__" 在 gz-sim 里不稳, 直接写 joint 本地 axis. -->
                <xyz>0 0 1</xyz>
                <limit>
                    <!-- effort: 仿真里 chassis 28kg 压 2 轮 (caster 不承重) → 静摩擦扭矩 ~10N·m/轮.
                         实车电机 2.4N·m 但配减速箱 + 腿部杠杆, 有效扭矩远大于 2.4.
                         仿真无减速箱/无腿部力学, 直接设 30N·m 保证能启动 + 有加速余量. -->
                    <effort>30</effort>
                    <velocity>80</velocity>
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
                <dynamics>
                    <damping>0.05</damping>
                </dynamics>
            </axis>
        </joint>
        <link name="left_wheel">
            <pose relative_to="left_wheel_joint">0 0 0 0 0 0</pose>
            <inertial>
                <!-- 1kg, r=0.060, w=0.04. ixx=iyy=m/12*(3r²+w²)=0.0010, izz=0.5*m*r²=0.0018 -->
                <mass>1.0</mass>
                <inertia>
                    <ixx>0.0010</ixx>
                    <iyy>0.0010</iyy>
                    <izz>0.0018</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.15 0.15 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.2</mu>
                            <mu2>1.0</mu2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1e7</kp>
                            <kd>500</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <!--right wheel (同轴, x=0, z=-leg_len 模拟虚拟腿)-->
        <joint name="right_wheel_joint" type="revolute">
            <pose relative_to="chassis">0 ${neg_half_wheel_sep} ${neg_leg_len} -1.5708 0 0</pose>
            <parent>chassis</parent>
            <child>right_wheel</child>
            <axis>
                <!-- 同 left_wheel_joint: joint_z = model_y (轮轴方向) -->
                <xyz>0 0 1</xyz>
                <limit>
                    <effort>30</effort>
                    <velocity>80</velocity>
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
                <dynamics>
                    <damping>0.05</damping>
                </dynamics>
            </axis>
        </joint>
        <link name="right_wheel">
            <pose relative_to="right_wheel_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>1.0</mass>
                <inertia>
                    <ixx>0.0010</ixx>
                    <iyy>0.0010</iyy>
                    <izz>0.0018</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.15 0.15 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>${wheel_radius}</radius>
                        <length>${wheel_width}</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.2</mu>
                            <mu2>1.0</mu2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1e7</kp>
                            <kd>500</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <!--front caster ball (模拟平衡控制器维持前倾支撑, 摩擦极低不干扰转向)-->
        <joint name="front_caster_joint" type="fixed">
            <pose relative_to="chassis">${caster_offset} 0 ${caster_z} 0 0 0</pose>
            <parent>chassis</parent>
            <child>front_caster</child>
        </joint>
        <link name="front_caster">
            <pose relative_to="front_caster_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.00004</ixx>
                    <iyy>0.00004</iyy>
                    <izz>0.00004</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <sphere><radius>${caster_radius}</radius></sphere>
                </geometry>
                <material>
                    <ambient>0.3 0.3 0.1 1</ambient>
                    <diffuse>0.4 0.4 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <sphere><radius>${caster_radius}</radius></sphere>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.001</mu>
                            <mu2>0.001</mu2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1e6</kp>
                            <kd>100</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <!--rear caster ball-->
        <joint name="rear_caster_joint" type="fixed">
            <pose relative_to="chassis">${neg_caster_offset} 0 ${caster_z} 0 0 0</pose>
            <parent>chassis</parent>
            <child>rear_caster</child>
        </joint>
        <link name="rear_caster">
            <pose relative_to="rear_caster_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.00004</ixx>
                    <iyy>0.00004</iyy>
                    <izz>0.00004</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <sphere><radius>${caster_radius}</radius></sphere>
                </geometry>
                <material>
                    <ambient>0.3 0.3 0.1 1</ambient>
                    <diffuse>0.4 0.4 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <sphere><radius>${caster_radius}</radius></sphere>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.001</mu>
                            <mu2>0.001</mu2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1e6</kp>
                            <kd>100</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <!--gimbal yaw joint (independent from chassis orientation)-->
        <joint name="gimbal_yaw_joint" type="revolute">
            <pose relative_to="chassis">0 0 ${gimbal_yaw_height} 0 0 0</pose>
            <parent>chassis</parent>
            <child>gimbal_yaw</child>
            <axis>
                <xyz>0 0 1</xyz>
                <limit>
                    <effort>20</effort>
                    <velocity>50</velocity>
                    <lower>-1.79769e+308</lower>
                    <upper>1.79769e+308</upper>
                </limit>
            </axis>
        </joint>
        <link name="gimbal_yaw">
            <pose relative_to="gimbal_yaw_joint">0 0 0 0 0 0</pose>
            <inertial>
                <pose>0 0 0.04 0 0 0</pose>
                <mass>0.5</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.0015</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0.04 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.08 0.08 0.08</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.4 0.4 0.45 1</ambient>
                    <diffuse>0.5 0.5 0.55 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0 0 0.04 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.08 0.08 0.08</size>
                    </box>
                </geometry>
            </collision>
        </link>

        <!--gimbal pitch joint-->
        <joint name="gimbal_pitch_joint" type="revolute">
            <pose relative_to="gimbal_yaw">0 0 ${gimbal_pitch_height} 0 0 0</pose>
            <parent>gimbal_yaw</parent>
            <child>gimbal_pitch</child>
            <axis>
                <xyz>0 1 0</xyz>
                <limit>
                    <effort>20</effort>
                    <velocity>50</velocity>
                    <lower>${-3.14*0.25}</lower>
                    <upper>${3.14*0.18}</upper>
                </limit>
            </axis>
        </joint>
        <link name="gimbal_pitch">
            <pose relative_to="gimbal_pitch_joint">0 0 0 0 0 0</pose>
            <inertial>
                <pose>0.03 0 0 0 0 0</pose>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.0005</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.001</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0.03 0 0 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.12 0.06 0.06</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.5 0.2 0.2 1</ambient>
                    <diffuse>0.6 0.25 0.25 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0.03 0 0 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.12 0.06 0.06</size>
                    </box>
                </geometry>
            </collision>
        </link>

        <!--LiDAR (Livox Mid360) mounted on gimbal_pitch, rotates with gimbal.
             Only the sensor frame is allowed to be tilted / inverted; chassis and gimbal
             remain upright in TF semantics. Simulation keeps a fixed 30 deg downward sensor
             pitch so near low bases enter the lower VFOV. -->
        <xmacro_block name="livox" prefix="front_" parent="gimbal_pitch" pose="-0.05 0 0.05 ${front_lidar_mount_roll} ${front_lidar_mount_pitch} ${front_lidar_mount_yaw}" update_rate="50" samples="1875"/>

        <!--industrial camera mounted on gimbal_pitch-->
        <xmacro_block name="industrial_camera" prefix="front_" parent="gimbal_pitch" pose="0.08 0 0.02 0 0 0" update_rate="30" horizontal_fov="1" width="1920" height="1080"/>

        <!--joint state publisher-->
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
        </plugin>

        <!--differential drive: 2 轮同轴, 两轮反向同速 → 原地自旋
             不显式指定 topic, gz-sim 默认用 /model/<model_name>/cmd_vel -->
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>
            <wheel_separation>${wheel_separation}</wheel_separation>
            <wheel_radius>${wheel_radius}</wheel_radius>
            <odom_publish_frequency>0</odom_publish_frequency>
            <frame_id>odom</frame_id>
            <child_frame_id>chassis</child_frame_id>
            <tf_topic>/tf_diff_drive_unused</tf_topic>
        </plugin>

        <!--gimbal yaw joint controller-->
        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>gimbal_yaw_joint</joint_name>
            <use_force_commands>false</use_force_commands>
            <p_gain>0.2</p_gain>
            <i_gain>0.01</i_gain>
        </plugin>

        <!--gimbal pitch joint controller-->
        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>gimbal_pitch_joint</joint_name>
            <use_force_commands>false</use_force_commands>
            <p_gain>1</p_gain>
            <i_gain>0.01</i_gain>
        </plugin>
    </model>
</sdf>
