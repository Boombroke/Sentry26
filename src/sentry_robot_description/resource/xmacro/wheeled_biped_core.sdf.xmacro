<?xml version="1.0"?>
<sdf version="1.8">

    <xmacro_include uri="model://mid360/model.sdf.xmacro" />
    <xmacro_include uri="model://industrial_camera/model.sdf.xmacro" />

    <!-- Real robot TF-only LiDAR block. Gazebo sensors stay in the sim profile. -->
    <xmacro_define_block name="wheeled_biped_livox_real" params="prefix parent pose">
        <joint name="${prefix}livox_joint" type="fixed">
            <pose relative_to="${parent}">${pose}</pose>
            <parent>${parent}</parent>
            <child>${prefix}mid360</child>
        </joint>
        <link name="${prefix}mid360">
            <pose relative_to="${prefix}livox_joint">0.0 0.0 0.0 0 0 0</pose>
            <inertial>
                <pose>0 0 0.02 0 0 0</pose>
                <xmacro_block name="inertia_cylinder" m="0.005" r="0.04" l="0.04" />
            </inertial>
            <visual name="visual">
                <pose>0.0 0.0 0.0 0 0 3.141592653589793</pose>
                <geometry>
                    <mesh>
                        <uri>model://mid360/meshes/mid360.dae</uri>
                    </mesh>
                </geometry>
            </visual>
        </link>
    </xmacro_define_block>

    <!-- Real robot TF-only camera block. The sim profile uses the Gazebo camera block. -->
    <xmacro_define_block name="wheeled_biped_industrial_camera_real" params="prefix parent pose">
        <joint name="${prefix}industrial_camera_joint" type="fixed">
            <pose relative_to="${parent}">${pose}</pose>
            <parent>${parent}</parent>
            <child>${prefix}industrial_camera</child>
        </joint>
        <link name="${prefix}industrial_camera">
            <pose relative_to="${prefix}industrial_camera_joint">0 0 0 0 0 0</pose>
            <inertial>
                <pose>0.025 0 0 0 0 0</pose>
                <xmacro_block name="inertia_box" m="0.050" x="0.08" y="0.025" z="0.033" />
            </inertial>
            <visual name="visual">
                <geometry>
                    <mesh>
                        <uri>model://industrial_camera/meshes/industrial_camera.dae</uri>
                    </mesh>
                </geometry>
            </visual>
            <collision name="collision">
                <pose>0.025 0 0 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.08 0.025 0.033</size>
                    </box>
                </geometry>
            </collision>
        </link>
        <joint name="${prefix}industrial_camera_optical_joint" type="fixed">
            <pose relative_to="${prefix}industrial_camera">0 0 0 -1.5707963267948966 0 -1.5707963267948966</pose>
            <parent>${prefix}industrial_camera</parent>
            <child>${prefix}industrial_camera_optical_frame</child>
        </joint>
        <link name="${prefix}industrial_camera_optical_frame">
            <pose relative_to="${prefix}industrial_camera_optical_joint">0 0 0 0 0 0</pose>
        </link>
    </xmacro_define_block>

    <!-- Gazebo-only caster support. The real robot has an active wheel-leg balancer instead. -->
    <xmacro_define_block name="wheeled_biped_casters">
        <joint name="front_caster_joint" type="fixed">
            <pose relative_to="chassis">0.28 0 -0.25 0 0 0</pose>
            <parent>chassis</parent>
            <child>front_caster</child>
        </joint>
        <link name="front_caster">
            <pose relative_to="front_caster_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.00004</ixx>
                    <iyy>0.00004</iyy>
                    <izz>0.00004</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <sphere>
                        <radius>0.03</radius>
                    </sphere>
                </geometry>
                <material>
                    <ambient>0.3 0.3 0.1 1</ambient>
                    <diffuse>0.4 0.4 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <sphere>
                        <radius>0.03</radius>
                    </sphere>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.001</mu>
                            <mu2>0.001</mu2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1e6</kp>
                            <kd>100</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>

        <joint name="rear_caster_joint" type="fixed">
            <pose relative_to="chassis">-0.28 0 -0.25 0 0 0</pose>
            <parent>chassis</parent>
            <child>rear_caster</child>
        </joint>
        <link name="rear_caster">
            <pose relative_to="rear_caster_joint">0 0 0 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.00004</ixx>
                    <iyy>0.00004</iyy>
                    <izz>0.00004</izz>
                    <ixy>0</ixy>
                    <ixz>0</ixz>
                    <iyz>0</iyz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <sphere>
                        <radius>0.03</radius>
                    </sphere>
                </geometry>
                <material>
                    <ambient>0.3 0.3 0.1 1</ambient>
                    <diffuse>0.4 0.4 0.15 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <sphere>
                        <radius>0.03</radius>
                    </sphere>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.001</mu>
                            <mu2>0.001</mu2>
                        </ode>
                    </friction>
                    <contact>
                        <ode>
                            <kp>1e6</kp>
                            <kd>100</kd>
                            <min_depth>0.001</min_depth>
                        </ode>
                    </contact>
                </surface>
            </collision>
        </link>
    </xmacro_define_block>

    <!-- Gazebo-only systems. Real hardware consumes /cmd_vel through rm_serial_driver. -->
    <xmacro_define_block name="wheeled_biped_gazebo_plugins">
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
        </plugin>

        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>left_wheel_joint</left_joint>
            <right_joint>right_wheel_joint</right_joint>
            <wheel_separation>0.65</wheel_separation>
            <wheel_radius>0.06</wheel_radius>
            <odom_publish_frequency>0</odom_publish_frequency>
            <frame_id>odom</frame_id>
            <child_frame_id>chassis</child_frame_id>
            <tf_topic>/tf_diff_drive_unused</tf_topic>
        </plugin>

        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>gimbal_yaw_joint</joint_name>
            <use_force_commands>false</use_force_commands>
            <p_gain>0.2</p_gain>
            <i_gain>0.01</i_gain>
        </plugin>

        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>gimbal_pitch_joint</joint_name>
            <use_force_commands>false</use_force_commands>
            <p_gain>1</p_gain>
            <i_gain>0.01</i_gain>
        </plugin>
    </xmacro_define_block>

    <xmacro_define_block name="wheeled_biped_chassis_imu">
        <sensor name="chassis_imu" type="imu">
            <always_on>1</always_on>
            <update_rate>200</update_rate>
        </sensor>
    </xmacro_define_block>

    <xmacro_define_block name="wheeled_biped_model" params="model_name chassis_length chassis_width chassis_z front_lidar_pose use_sim_sensors use_real_sensors use_casters use_gazebo_plugins">
        <model name="${model_name}" canonical_link="chassis" placement_frame="base_footprint">
            <pose>0 0 0 0 0 0</pose>

            <link name="base_footprint">
                <inertial>
                    <mass>0.001</mass>
                    <inertia>
                        <ixx>1e-6</ixx>
                        <iyy>1e-6</iyy>
                        <izz>1e-6</izz>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyz>0</iyz>
                    </inertia>
                </inertial>
            </link>

            <joint name="base_to_chassis" type="fixed">
                <pose relative_to="base_footprint">0 0 0.28 0 0 0</pose>
                <parent>base_footprint</parent>
                <child>chassis</child>
            </joint>

            <link name="chassis">
                <inertial>
                    <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                    <xmacro_block name="inertia_box" m="28.0" x="${chassis_length}" y="${chassis_width}" z="${chassis_z}" />
                </inertial>
                <visual name="chassis_visual">
                    <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                    <geometry>
                        <box>
                            <size>${chassis_length} ${chassis_width} ${chassis_z}</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>0.2 0.2 0.25 1</ambient>
                        <diffuse>0.3 0.3 0.35 1</diffuse>
                    </material>
                </visual>
                <collision name="chassis_collision">
                    <pose>0 0 ${chassis_z / 2} 0 0 0</pose>
                    <geometry>
                        <box>
                            <size>${chassis_length} ${chassis_width} ${chassis_z}</size>
                        </box>
                    </geometry>
                    <surface>
                        <friction>
                            <ode>
                                <mu>0.3</mu>
                                <mu2>0.3</mu2>
                            </ode>
                        </friction>
                    </surface>
                </collision>
                <xmacro_block condition="${use_sim_sensors}" name="wheeled_biped_chassis_imu" />
            </link>

            <joint name="left_wheel_joint" type="revolute">
                <pose relative_to="chassis">0 0.325 -0.22 -1.5708 0 0</pose>
                <parent>chassis</parent>
                <child>left_wheel</child>
                <axis>
                    <xyz>0 0 1</xyz>
                    <limit>
                        <effort>30</effort>
                        <velocity>80</velocity>
                        <lower>-1.79769e+308</lower>
                        <upper>1.79769e+308</upper>
                    </limit>
                    <dynamics>
                        <damping>0.05</damping>
                    </dynamics>
                </axis>
            </joint>
            <link name="left_wheel">
                <pose relative_to="left_wheel_joint">0 0 0 0 0 0</pose>
                <inertial>
                    <mass>1.0</mass>
                    <inertia>
                        <ixx>0.0010</ixx>
                        <iyy>0.0010</iyy>
                        <izz>0.0018</izz>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyz>0</iyz>
                    </inertia>
                </inertial>
                <visual name="visual">
                    <geometry>
                        <cylinder>
                            <radius>0.06</radius>
                            <length>0.04</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0.15 0.15 0.15 1</diffuse>
                    </material>
                </visual>
                <collision name="collision">
                    <geometry>
                        <cylinder>
                            <radius>0.06</radius>
                            <length>0.04</length>
                        </cylinder>
                    </geometry>
                    <surface>
                        <friction>
                            <ode>
                                <mu>1.2</mu>
                                <mu2>1.0</mu2>
                            </ode>
                        </friction>
                        <contact>
                            <ode>
                                <kp>1e7</kp>
                                <kd>500</kd>
                                <min_depth>0.001</min_depth>
                            </ode>
                        </contact>
                    </surface>
                </collision>
            </link>

            <joint name="right_wheel_joint" type="revolute">
                <pose relative_to="chassis">0 -0.325 -0.22 -1.5708 0 0</pose>
                <parent>chassis</parent>
                <child>right_wheel</child>
                <axis>
                    <xyz>0 0 1</xyz>
                    <limit>
                        <effort>30</effort>
                        <velocity>80</velocity>
                        <lower>-1.79769e+308</lower>
                        <upper>1.79769e+308</upper>
                    </limit>
                    <dynamics>
                        <damping>0.05</damping>
                    </dynamics>
                </axis>
            </joint>
            <link name="right_wheel">
                <pose relative_to="right_wheel_joint">0 0 0 0 0 0</pose>
                <inertial>
                    <mass>1.0</mass>
                    <inertia>
                        <ixx>0.0010</ixx>
                        <iyy>0.0010</iyy>
                        <izz>0.0018</izz>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyz>0</iyz>
                    </inertia>
                </inertial>
                <visual name="visual">
                    <geometry>
                        <cylinder>
                            <radius>0.06</radius>
                            <length>0.04</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>0.1 0.1 0.1 1</ambient>
                        <diffuse>0.15 0.15 0.15 1</diffuse>
                    </material>
                </visual>
                <collision name="collision">
                    <geometry>
                        <cylinder>
                            <radius>0.06</radius>
                            <length>0.04</length>
                        </cylinder>
                    </geometry>
                    <surface>
                        <friction>
                            <ode>
                                <mu>1.2</mu>
                                <mu2>1.0</mu2>
                            </ode>
                        </friction>
                        <contact>
                            <ode>
                                <kp>1e7</kp>
                                <kd>500</kd>
                                <min_depth>0.001</min_depth>
                            </ode>
                        </contact>
                    </surface>
                </collision>
            </link>

            <xmacro_block condition="${use_casters}" name="wheeled_biped_casters" />

            <joint name="gimbal_yaw_joint" type="revolute">
                <pose relative_to="chassis">0 0 0.18 0 0 0</pose>
                <parent>chassis</parent>
                <child>gimbal_yaw</child>
                <axis>
                    <xyz>0 0 1</xyz>
                    <limit>
                        <effort>20</effort>
                        <velocity>50</velocity>
                        <lower>-1.79769e+308</lower>
                        <upper>1.79769e+308</upper>
                    </limit>
                </axis>
            </joint>
            <link name="gimbal_yaw">
                <pose relative_to="gimbal_yaw_joint">0 0 0 0 0 0</pose>
                <inertial>
                    <pose>0 0 0.04 0 0 0</pose>
                    <mass>0.5</mass>
                    <inertia>
                        <ixx>0.001</ixx>
                        <iyy>0.001</iyy>
                        <izz>0.0015</izz>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyz>0</iyz>
                    </inertia>
                </inertial>
                <visual name="visual">
                    <pose>0 0 0.04 0 0 0</pose>
                    <geometry>
                        <box>
                            <size>0.08 0.08 0.08</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>0.4 0.4 0.45 1</ambient>
                        <diffuse>0.5 0.5 0.55 1</diffuse>
                    </material>
                </visual>
                <collision name="collision">
                    <pose>0 0 0.04 0 0 0</pose>
                    <geometry>
                        <box>
                            <size>0.08 0.08 0.08</size>
                        </box>
                    </geometry>
                </collision>
            </link>

            <joint name="gimbal_pitch_joint" type="revolute">
                <pose relative_to="gimbal_yaw">0 0 0.08 0 0 0</pose>
                <parent>gimbal_yaw</parent>
                <child>gimbal_pitch</child>
                <axis>
                    <xyz>0 1 0</xyz>
                    <limit>
                        <effort>20</effort>
                        <velocity>50</velocity>
                        <lower>-0.785</lower>
                        <upper>0.5652</upper>
                    </limit>
                </axis>
            </joint>
            <link name="gimbal_pitch">
                <pose relative_to="gimbal_pitch_joint">0 0 0 0 0 0</pose>
                <inertial>
                    <pose>0.03 0 0 0 0 0</pose>
                    <mass>0.3</mass>
                    <inertia>
                        <ixx>0.0005</ixx>
                        <iyy>0.001</iyy>
                        <izz>0.001</izz>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyz>0</iyz>
                    </inertia>
                </inertial>
                <visual name="visual">
                    <pose>0.03 0 0 0 0 0</pose>
                    <geometry>
                        <box>
                            <size>0.12 0.06 0.06</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>0.5 0.2 0.2 1</ambient>
                        <diffuse>0.6 0.25 0.25 1</diffuse>
                    </material>
                </visual>
                <collision name="collision">
                    <pose>0.03 0 0 0 0 0</pose>
                    <geometry>
                        <box>
                            <size>0.12 0.06 0.06</size>
                        </box>
                    </geometry>
                </collision>
            </link>

            <xmacro_block condition="${use_sim_sensors}" name="livox" prefix="front_" parent="gimbal_pitch" pose="${front_lidar_pose}" update_rate="50" samples="1875" />
            <xmacro_block condition="${use_real_sensors}" name="wheeled_biped_livox_real" prefix="front_" parent="gimbal_pitch" pose="${front_lidar_pose}" />

            <xmacro_block condition="${use_sim_sensors}" name="industrial_camera" prefix="front_" parent="gimbal_pitch" pose="0.08 0 0.02 0 0 0" update_rate="30" horizontal_fov="1" width="1920" height="1080" />
            <xmacro_block condition="${use_real_sensors}" name="wheeled_biped_industrial_camera_real" prefix="front_" parent="gimbal_pitch" pose="0.08 0 0.02 0 0 0" />

            <xmacro_block condition="${use_gazebo_plugins}" name="wheeled_biped_gazebo_plugins" />
        </model>
    </xmacro_define_block>
</sdf>
