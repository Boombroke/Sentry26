<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="3"
      main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode name="NavigateRecovery"
                  number_of_retries="10">
      <PipelineSequence name="NavigateWithReplanning">
        <RateController hz="5.0">
          <RecoveryNode name="ComputePathThroughPoses"
                        number_of_retries="1">
            <ReactiveSequence>
              <RemovePassedGoals input_goals="{goals}"
                                 output_goals="{goals}"
                                 radius="0.7"/>
              <ComputePathThroughPoses goals="{goals}"
                                       path="{path}"
                                       planner_id="GridBased"/>
            </ReactiveSequence>
            <ClearEntireCostmap name="ClearGlobalCostmap-Context"
                                service_name="global_costmap/clear_entirely_global_costmap"/>
          </RecoveryNode>
        </RateController>
        <RecoveryNode name="FollowPath"
                      number_of_retries="3">
          <FollowPath path="{path}"
                      controller_id="FollowPath"/>
          <ClearEntireCostmap name="ClearLocalCostmap-Context"
                              service_name="local_costmap/clear_entirely_local_costmap"/>
        </RecoveryNode>
      </PipelineSequence>
      <ReactiveFallback name="RecoveryFallback">
        <GoalUpdated/>
        <RoundRobin name="RecoveryActions">
          <Sequence name="MotionManagerRecoveryPlaceholder">
            <!-- sentry_motion_manager owns /cmd_vel now. Keep this BT parseable
                 until a dedicated Nav2 recovery trigger adapter is available. -->
            <ClearEntireCostmap name="ClearLocalCostmap-Subtree"
                                service_name="local_costmap/clear_entirely_local_costmap"/>
            <ClearEntireCostmap name="ClearGlobalCostmap-Subtree"
                                service_name="global_costmap/clear_entirely_global_costmap"/>
            <Wait wait_duration="1"/>
          </Sequence>
        </RoundRobin>
      </ReactiveFallback>
    </RecoveryNode>
  </BehaviorTree>
</root>
